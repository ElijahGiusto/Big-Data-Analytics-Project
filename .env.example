# =============================================================================
# API Credentials
# Copy this file to .env and fill in your actual credentials.
# DO NOT commit .env to version control.
# =============================================================================

# Spotify API (optional; disabled by default in config/settings.yaml)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Last.fm API (https://www.last.fm/api/account/create)
LASTFM_API_KEY=your_lastfm_api_key

# Optional TheAudioDB override.
# The project defaults to the documented free key in config/settings.yaml.
THEAUDIODB_API_KEY=123

# Deezer, MusicBrainz, ListenBrainz, Wikimedia, iTunes, and Wikidata require no credentials
